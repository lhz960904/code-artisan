# Database (from Supabase dashboard → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# LLM provider (Anthropic / aihubmix / any OpenAI-compatible gateway).
# Leave LLM_BASE_URL unset to use provider defaults.
LLM_API_KEY=sk-xxx
LLM_BASE_URL=

# E2B
E2B_API_KEY=e2b_xxx

# Tavily (web search, optional)
TAVILY_API_KEY=tvly-xxx

# Integration OAuth (Vercel + Supabase BYO)
# Generate INTEGRATION_SECRET_KEY with: openssl rand -base64 32
INTEGRATION_SECRET_KEY=
# Vercel: register at https://vercel.com/dashboard/integrations/console
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
# Must match the Redirect URL registered on the Vercel integration form.
# Use the FRONTEND port (3000) so cookies stay scoped consistently — Vite proxies /api to :3001.
VERCEL_OAUTH_REDIRECT_URI=http://localhost:3000/api/integration/vercel/callback
# The URL Slug from the Vercel integration form (the human-readable name, e.g. `code-artisan`).
# Install URL is `https://vercel.com/integrations/<slug>/new` — NOT the client_id.
VERCEL_INTEGRATION_SLUG=code-artisan

# Supabase OAuth (BYO Supabase): register at any org → Org Settings → OAuth Apps → New Application.
# Redirect URL on the Supabase form must match SUPABASE_OAUTH_REDIRECT_URI exactly.
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integration/supabase/callback
# Optional: scope string the OAuth app was registered with (e.g. `all`). Leave blank to default to `all`.
SUPABASE_OAUTH_SCOPE=
