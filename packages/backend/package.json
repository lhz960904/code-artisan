{
  "name": "@code-artisan/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:push": "dotenv -e ../../.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -- drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-auth": "^1.2.0",
    "@code-artisan/agent": "workspace:*",
    "@code-artisan/shared": "workspace:*",
    "@e2b/code-interpreter": "^1.0.4",
    "@hono/standard-validator": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@standard-schema/spec": "^1.1.0",
    "@supabase/supabase-js": "^2.49.1",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6",
    "zod-from-json-schema": "^0.5.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
