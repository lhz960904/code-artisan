{
  "name": "code-artisan",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter @code-artisan/frontend dev",
    "dev:backend": "pnpm --filter @code-artisan/backend dev",
    "dev": "pnpm --parallel --filter @code-artisan/frontend --filter @code-artisan/backend dev",
    "build": "pnpm --filter @code-artisan/shared build && pnpm --filter @code-artisan/frontend build && pnpm --filter @code-artisan/backend build",
    "test": "pnpm --filter @code-artisan/agent test && pnpm --filter @code-artisan/backend test"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
